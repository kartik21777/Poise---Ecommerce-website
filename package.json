    "seed:store-credit": "tsx server/scripts/generateStoreCredit.ts",
    "seed:loyalty": "tsx server/scripts/generateLoyalty.ts",
    "seed:orders": "tsx server/scripts/generateOrders.ts",
    "seed:payments": "tsx server/scripts/generatePayments.ts"
  },
  "dependencies": {
