# ==============================================================================
# PRODUCTION ENVIRONMENT CONFIGURATION (TEMPLATE)
# ==============================================================================

# ── SYSTEM ──────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
CLIENT_URL=https://your-production-domain.com
# Enable only for demo environments that should contain generated commerce data.
ENABLE_DEMO_DATA=false

# ── DATABASE ────────────────────────────────────────────────────────────────
# Use a production-grade MongoDB URI with a replica set (required for transactions)
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/poise?retryWrites=true&w=majority

# ── AUTHENTICATION ──────────────────────────────────────────────────────────
# Use strong random strings for JSON Web Tokens
JWT_SECRET=generate_a_strong_64_character_random_string_here
JWT_EXPIRE=7d

# ── PAYMENTS ────────────────────────────────────────────────────────────────
# Stripe
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Razorpay
RAZORPAY_KEY_ID=rzp_live_...
RAZORPAY_KEY_SECRET=...
RAZORPAY_WEBHOOK_SECRET=...

# ── CLOUD STORAGE (FILE UPLOADS) ────────────────────────────────────────────
# Set this to production cloud storage (Cloudinary or AWS S3)
STORAGE_PROVIDER=cloudinary
CLOUDINARY_CLOUD_NAME=...
CLOUDINARY_API_KEY=...
CLOUDINARY_API_SECRET=...

# ── EMAIL / SMTP ────────────────────────────────────────────────────────────
SMTP_HOST=smtp.your-email-provider.com
SMTP_PORT=465
SMTP_USER=no-reply@your-production-domain.com
SMTP_PASS=...
EMAIL_FROM=POISE <no-reply@your-production-domain.com>

# ── AI / EXTERNAL SERVICES ──────────────────────────────────────────────────
GEMINI_API_KEY=...
